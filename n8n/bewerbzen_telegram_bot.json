        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: \"claude-opus-4-5\", max_tokens: 2000, messages: [{ role: \"user\", content: \"Напиши профессиональный Anschreiben на немецком языке. Используй [квадратные скобки] для данных которые соискатель заменит сам.\\n\\nВакансия:\\n\" + $json.text }] }) }}",
        "options": {}
      }
    },
    {
      "id": "format",
      "name": "Format Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1780,
        680
      ],
      "parameters": {
        "jsCode": "\nconst data = $getWorkflowStaticData('global');\nconst chatId = String($input.first().json.chatId);\nif (data.users?.[chatId]) data.users[chatId].count += 1;\nconst count = data.users?.[chatId]?.count || 1;\nconst anschreiben = $input.first().json?.content?.[0]?.text || 'Ошибка — попробуй снова (/bewerben).';\nreturn [{ json: { ...$input.first().json, anschreiben, usageCountAfter: count, remaining: Math.max(0,3-count) } }];\n"
      }
    },
