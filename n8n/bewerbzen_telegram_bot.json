    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "REPLACE_WITH_CLAUDE_API_KEY"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={\n  \"model\": \"claude-opus-4-5\",\n  \"max_tokens\": 1200,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Du bist ein erfahrener Karriereberater in Deutschland mit 15 Jahren Erfahrung. Erstelle ein professionelles, überzeugendes Anschreiben auf Deutsch nach aktuellem deutschen Standard.\\n\\nAnforderungen:\\n- Klassischer Aufbau: Ort und Datum, Betreff, Anrede, 3 Absätze, Schluss\\n- Formeller aber nicht steifer Stil — überzeugend und authentisch\\n- Direkt auf die Stelle zugeschnitten — keine Floskeln\\n- ATS-optimiert: wichtige Keywords aus der Stellenanzeige natürlich einbauen\\n- Länge: 250–320 Wörter\\n- Platzhalter für persönliche Daten in [eckigen Klammern]\\n\\nFormat des Anschreibens:\\n[Vorname Nachname]\\n[Straße Nr.]\\n[PLZ Stadt]\\n[E-Mail] | [Telefon]\\n\\n[Stadt], [Datum]\\n\\n[Firmenname]\\nz. Hd. [Ansprechpartner oder \\\"die Personalabteilung\\\"]\\n[Adresse des Unternehmens]\\n\\nBetreff: Bewerbung als [Stelle] — Ihre Stellenausschreibung vom [Datum]\\n\\nSehr geehrte Damen und Herren,\\n\\n[Absatz 1: Einstieg mit Bezug zur Stelle und kurzem Stärken-Hook]\\n\\n[Absatz 2: Relevante Erfahrungen und Kompetenzen — konkret, mit Zahlen wenn möglich]\\n\\n[Absatz 3: Motivation für genau dieses Unternehmen + Abschluss mit klarem Call to Action]\\n\\nMit freundlichen Grüßen,\\n\\n[Vorname Nachname]\\n\\n---\\nNachricht des Bewerbers / Stellenbeschreibung:\\n{{ $json.text }}\\n\\nGib NUR den vollständigen Anschreiben-Text zurück. Keine Erklärungen, keine Kommentare, kein JSON — nur den Brief.\"\n    }\n  ]\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "claude-api",
      "name": "Claude API — Anschreiben",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1780,
        620
      ]
