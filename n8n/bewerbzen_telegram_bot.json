    {
      "id": "check-limit",
      "name": "Check Limit",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        760
      ],
      "parameters": {
        "jsCode": "\nconst data = $getWorkflowStaticData('global');\nif (!data.users) data.users = {};\nconst chatId = String($input.first().json.chatId);\nif (!data.users[chatId]) data.users[chatId] = { count: 0, isPaid: false };\nconst user = data.users[chatId];\nconst limitOk = user.isPaid || user.count < 3;\nreturn [{ json: { ...$input.first().json, usageCount: user.count, limitOk } }];\n"
      }
    },
