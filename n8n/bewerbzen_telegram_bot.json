    {
      "id": "parse",
      "name": "Parse Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        420,
        400
      ],
      "parameters": {
        "jsCode": "\nconst msg = $input.first().json?.message || {};\nconst text = (msg.text || '').trim();\nconst chatId = String(msg.chat?.id || '');\nconst firstName = msg.from?.first_name || 'друг';\nconst isCmd = text.startsWith('/');\nconst raw = isCmd ? text.split(' ')[0].replace('/','').split('@')[0].toLowerCase() : '';\nconst known = ['start','help','bewerben','status'];\nconst command = isCmd ? (known.includes(raw) ? raw : 'unknown') : 'text';\nreturn [{ json: { chatId, firstName, text, command } }];\n"
      }
    },
