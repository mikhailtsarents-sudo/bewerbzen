        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ chat_id: $json.chatId, parse_mode: \"Markdown\", text: \"Привет, \" + $json.firstName + \"! 👋\\n\\nЯ — *BewerbZen*. Помогаю русскоязычным в Германии делать Bewerbung быстро и правильно.\\n\\n📋 *Что умею:*\\n• Anschreiben под вакансию\\n• Lebenslauf по немецкому стандарту\\n\\nПришли текст вакансии или напиши /bewerben\\n\\n✨ *Первые 3 Bewerbung — бесплатно*\" }) }}",
        "options": {}
      }
    },
