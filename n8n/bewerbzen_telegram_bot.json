    {
      "parameters": {
        "jsCode": "const msg = $input.first().json.message;\nconst text = (msg?.text || '').trim();\nconst chatId = msg?.chat?.id;\nconst userId = String(msg?.from?.id || '');\nconst firstName = msg?.from?.first_name || 'друг';\n\nlet command = 'text';\nif (text.startsWith('/start'))    command = 'start';\nelse if (text.startsWith('/help')) command = 'help';\nelse if (text.startsWith('/bewerben') || text.startsWith('/bewerbung')) command = 'bewerben';\nelse if (text.startsWith('/status'))  command = 'status';\nelse if (text.startsWith('/'))         command = 'unknown_cmd';\n\nreturn [{ json: { chatId, userId, firstName, text, command, rawMessage: msg } }];"
      },
