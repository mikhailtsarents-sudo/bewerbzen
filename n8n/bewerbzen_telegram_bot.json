    {
      "id": "check-limit-001",
      "name": "Check & Track Usage",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        620
      ],
      "parameters": {
        "jsCode": "\n// Read persistent usage data stored in workflow static data\nconst data = $getWorkflowStaticData('global');\nif (!data.users) data.users = {};\n\nconst chatId = String($input.first().json.chatId);\nif (!data.users[chatId]) {\n  data.users[chatId] = { count: 0, isPaid: false, firstName: $input.first().json.firstName || '' };\n}\n\nconst user = data.users[chatId];\nconst FREE_LIMIT = 3;\nconst limitOk = user.isPaid || user.count < FREE_LIMIT;\n\n// Pass everything through, adding limitOk flag\nreturn [{\n  json: {\n    ...$input.first().json,\n    usageCount: user.count,\n    isPaid: user.isPaid,\n    limitOk: limitOk\n  }\n}];\n"
      }
    },
    {
      "id": "limit-router-001",
      "name": "Limit Router",
