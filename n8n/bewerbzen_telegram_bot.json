{
  "name": "BewerbZen Telegram Bot MVP",
  "nodes": [
    {
      "id": "tg-trigger",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [
        220,
        300
      ],
      "parameters": {
        "updates": [
          "message"
        ],
        "additionalFields": {}
      },
      "credentials": {
        "telegramApi": {
          "id": "QnYKdsbSqRsqqH0J",
          "name": "BewerbZen Bot"
        }
      }
    },
    {
      "id": "parse-msg",
      "name": "Parse Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        300
      ],
      "parameters": {
        "jsCode": "\nconst msg = $input.first().json?.message || {};\nconst text = msg.text || '';\nconst chatId = String(msg.chat?.id || '');\nconst firstName = msg.from?.first_name || 'друг';\nconst command = text.startsWith('/') ? text.split(' ')[0].replace('/','').split('@')[0].toLowerCase() : 'text';\n\nreturn [{ json: { chatId, firstName, text, command, isCommand: text.startsWith('/') } }];\n"
      }
    },
    {
      "id": "cmd-router",
      "name": "Command Router",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        660,
        300
      ],
      "parameters": {
        "rules": {
          "rules": [
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.command }}",
                    "rightValue": "start",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "start"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.command }}",
                    "rightValue": "help",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "help"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.command }}",
                    "rightValue": "bewerben",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "bewerben"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.command }}",
                    "rightValue": "status",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "status"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.isCommand }}",
                    "rightValue": "false",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "text"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      }
    },
    {
      "id": "send-welcome",
      "name": "Send Welcome",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        900,
        60
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot8734398212:AAH25Qdzy97iMOQyyfTX1neXz9cOadSaB5Q/sendMessage",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ chat_id: $json.chatId, text: \"Привет, \" + $json.firstName + \"! 👋\\n\\nЯ — BewerbZen. Помогаю русскоязычным в Германии делать Bewerbung правильно и быстро.\\n\\n📋 Что умею:\\n• Anschreiben под конкретную вакансию\\n• Lebenslauf по немецкому стандарту\\n• Поиск вакансий (скоро)\\n\\nНапиши /bewerben и пришли текст вакансии.\\n\\n✨ Первые 3 Bewerbung — бесплатно\", parse_mode: \"Markdown\" }) }}",
        "options": {}
      }
    },
    {
      "id": "send-help",
      "name": "Send Help",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        900,
        200
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot8734398212:AAH25Qdzy97iMOQyyfTX1neXz9cOadSaB5Q/sendMessage",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ chat_id: $json.chatId, text: \"📋 *BewerbZen — справка*\\n\\n/bewerben — составить Anschreiben\\n/status — баланс\\n/help — эта справка\\n\\n💡 Как получить лучший результат:\\n• Полный текст вакансии\\n• Уровень немецкого (B1/B2/C1)\\n\\n🆓 Первые 3 — бесплатно\\n💳 Пакет 3 шт — €4.99\\n♾️ Подписка — €12.99/мес\", parse_mode: \"Markdown\" }) }}",
        "options": {}
      }
    },
    {
      "id": "ask-vacancy",
      "name": "Ask for Vacancy",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        900,
        340
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot8734398212:AAH25Qdzy97iMOQyyfTX1neXz9cOadSaB5Q/sendMessage",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ chat_id: $json.chatId, text: \"Давай составим Bewerbung! ✍️\\n\\n*Пришли текст вакансии* — скопируй с сайта работодателя или со StepStone / Indeed / Xing.\\n\\nЧем полнее текст — тем точнее Anschreiben.\\n\\n💡 Опционально — добавь в конце:\\n«Я frontend-разработчик, 3 года опыта, B2 немецкий»\", parse_mode: \"Markdown\" }) }}",
        "options": {}
      }
    },
    {
      "id": "send-status",
      "name": "Send Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        900,
        480
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot8734398212:AAH25Qdzy97iMOQyyfTX1neXz9cOadSaB5Q/sendMessage",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ (() => { const data = $getWorkflowStaticData(\"global\"); const user = (data.users || {})[String($json.chatId)] || { count: 0, isPaid: false }; const rem = Math.max(0, 3 - user.count); return JSON.stringify({ chat_id: $json.chatId, text: \"📊 *Твой статус*\\n\\n✅ Использовано: \" + user.count + \" из 3 бесплатных\\n🎁 Осталось: \" + rem + \"\\n\\n\" + (rem > 0 ? \"Напиши /bewerben чтобы начать →\" : \"Бесплатные использованы. Напиши @mihailcarenc для продления.\"), parse_mode: \"Markdown\" }); })() }}",
        "options": {}
      }
    },
    {
      "id": "check-limit",
      "name": "Check & Track Usage",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        620
      ],
      "parameters": {
        "jsCode": "\nconst data = $getWorkflowStaticData('global');\nif (!data.users) data.users = {};\nconst chatId = String($input.first().json.chatId);\nif (!data.users[chatId]) data.users[chatId] = { count: 0, isPaid: false };\nconst user = data.users[chatId];\nconst FREE_LIMIT = 3;\nconst limitOk = user.isPaid || user.count < FREE_LIMIT;\nreturn [{ json: { ...$input.first().json, usageCount: user.count, isPaid: user.isPaid, limitOk: !!limitOk } }];\n"
      }
    },
    {
      "id": "limit-router",
      "name": "Limit Router",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1120,
        620
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "limit-router-cond",
              "leftValue": "={{ !!$json.limitOk }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "send-loading",
