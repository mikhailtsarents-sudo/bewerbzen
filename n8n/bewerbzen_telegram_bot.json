    {
      "id": "increment-count-001",
      "name": "Increment Usage Count",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1340,
        620
      ],
      "parameters": {
        "jsCode": "\n// Increment usage count after successful check\nconst data = $getWorkflowStaticData('global');\nconst chatId = String($input.first().json.chatId);\n\nif (data.users && data.users[chatId] !== undefined) {\n  data.users[chatId].count += 1;\n}\n\nconst remaining = 3 - (data.users[chatId]?.count || 1);\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    usageCountAfter: data.users[chatId]?.count || 1,\n    remaining: Math.max(0, remaining)\n  }\n}];\n"
      }
    }
