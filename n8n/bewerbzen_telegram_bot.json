    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst anschreiben = response.content?.[0]?.text || 'Не удалось сгенерировать. Попробуй ещё раз через /bewerben';\nconst chatId = $('Parse Message').first().json.chatId;\nconst firstName = $('Parse Message').first().json.firstName;\n\n// Trim and clean up\nconst cleaned = anschreiben.trim();\n\nreturn [{ json: { chatId, firstName, anschreiben: cleaned } }];"
      },
