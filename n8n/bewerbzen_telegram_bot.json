      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot8734398212:AAH25Qdzy97iMOQyyfTX1neXz9cOadSaB5Q/sendMessage",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ chat_id: $json.chatId, text: \"Ты использовал все *3 бесплатных Bewerbung* 🎉\\n\\nЧтобы продолжить:\\n💳 Пакет 3 шт — €4.99\\n♾️ Подписка — €12.99/мес\\n\\nНапиши @mihailcarenc для оплаты.\", parse_mode: \"Markdown\" }) }}",
        "options": {}
      }
    },
    {
      "id": "claude-api",
      "name": "Claude API — Anschreiben",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1560,
        540
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "REPLACE_WITH_CLAUDE_API_KEY"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: \"claude-opus-4-5\", max_tokens: 2000, messages: [{ role: \"user\", content: \"Ты эксперт по немецким заявлениям о приёме на работу (Bewerbung). Напиши профессиональный Anschreiben на немецком языке для следующей вакансии.\\n\\nВАЖНО: Используй [квадратные скобки] для данных которые соискатель должен заменить сам (имя, адрес, телефон, дата и т.д.)\\n\\nВакансия:\\n\" + $json.text }] }) }}",
        "options": {}
      }
    },
    {
      "id": "format-result",
      "name": "Format Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1780,
        540
      ],
      "parameters": {
        "jsCode": "\nconst data = $getWorkflowStaticData('global');\nconst chatId = String($input.first().json.chatId);\nif (data.users && data.users[chatId] !== undefined) {\n  data.users[chatId].count = (data.users[chatId].count || 0) + 1;\n}\nconst count = data.users?.[chatId]?.count || 1;\nconst remaining = Math.max(0, 3 - count);\n\nconst apiResp = $input.first().json;\nconst anschreiben = apiResp?.content?.[0]?.text || apiResp?.content || 'Ошибка генерации';\n\nconst firstName = $input.first().json.firstName || 'друг';\nreturn [{ json: { ...$input.first().json, anschreiben, usageCountAfter: count, remaining, firstName } }];\n"
      }
    },
    {
      "id": "send-result",
      "name": "Send Anschreiben",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2000,
        540
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot8734398212:AAH25Qdzy97iMOQyyfTX1neXz9cOadSaB5Q/sendMessage",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ chat_id: $json.chatId, text: \"✅ *Готово, \" + $json.firstName + \"!*\\n\\n```\\n\" + ($json.anschreiben || \"\").substring(0,3500) + \"\\n```\\n\\n📌 *Что дальше:*\\n1. Замени всё в [квадратных скобках] на свои данные\\n2. Проверь имя контактного лица\\n3. Сохрани как PDF (Google Docs → Файл → PDF)\\n\\n📊 Использовано: \" + $json.usageCountAfter + \" из 3 бесплатных ✨\", parse_mode: \"Markdown\" }) }}",
        "options": {}
      }
    },
