      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot8734398212:AAH25Qdzy97iMOQyyfTX1neXz9cOadSaB5Q/sendMessage",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ (() => { const d = $getWorkflowStaticData(\"global\"); const u = (d.users||{})[String($json.chatId)]||{count:0}; const r = Math.max(0,3-u.count); return JSON.stringify({ chat_id: $json.chatId, parse_mode: \"Markdown\", text: \"📊 *Твой статус*\\n\\nИспользовано: \"+u.count+\" из 3\\nОсталось бесплатно: \"+r }); })() }}",
        "options": {}
      }
