        "options": {}
      }
    },
    {
      "id": "claude-api",
      "name": "Claude API — Anschreiben",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1560,
        520
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "REPLACE_WITH_CLAUDE_API_KEY"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: \"claude-opus-4-5\", max_tokens: 2000, messages: [{ role: \"user\", content: \"Напиши профессиональный Anschreiben на немецком языке для следующей вакансии. Используй [квадратные скобки] для данных которые соискатель заменит сам.\\n\\nВакансия:\\n\" + $json.text }] }) }}",
        "options": {}
      }
    },
    {
      "id": "format-result",
      "name": "Format Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1780,
        520
      ],
      "parameters": {
        "jsCode": "\nconst data = $getWorkflowStaticData('global');\nconst chatId = String($input.first().json.chatId);\nif (data.users?.[chatId] !== undefined) data.users[chatId].count += 1;\nconst count = data.users?.[chatId]?.count || 1;\nconst anschreiben = $input.first().json?.content?.[0]?.text || 'Ошибка генерации — попробуй снова.';\nreturn [{ json: { ...$input.first().json, anschreiben, usageCountAfter: count, remaining: Math.max(0, 3 - count) } }];\n"
      }
    },
    {
      "id": "send-result",
      "name": "Send Anschreiben",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2000,
        520
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot8734398212:AAH25Qdzy97iMOQyyfTX1neXz9cOadSaB5Q/sendMessage",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ chat_id: $json.chatId, parse_mode: \"Markdown\", text: \"✅ *Готово, \" + $json.firstName + \"!*\\n\\n```\\n\" + ($json.anschreiben||\"\").substring(0,3800) + \"\\n```\\n\\n📌 *Что дальше:*\\n1. Замени [квадратные скобки] на свои данные\\n2. Сохрани как PDF\\n3. Приложи к заявке\\n\\n📊 Использовано: \" + $json.usageCountAfter + \" из 3 бесплатных ✨\" }) }}",
        "options": {}
      }
    },
