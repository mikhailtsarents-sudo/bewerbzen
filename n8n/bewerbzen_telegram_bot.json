        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ chat_id: $json.chatId, parse_mode: \"Markdown\", text: \"✅ *Готово, \" + $json.firstName + \"!*\\n\\n```\\n\" + ($json.anschreiben||\"\").substring(0,3800) + \"\\n```\\n\\n📌 Замени [квадратные скобки] на свои данные, сохрани как PDF.\\n\\n📊 Использовано: \" + $json.usageCountAfter + \" из 3 ✨\" }) }}",
        "options": {}
      }
    }
