        "additionalFields": {
          "parse_mode": "Markdown",
          "reply_markup": "{\"inline_keyboard\": [[{\"text\": \"💳 Пакет 3 шт — €4.99\", \"url\": \"https://bewerbzen.de/#pricing\"}, {\"text\": \"♾️ Подписка — €12.99\", \"url\": \"https://bewerbzen.de/#pricing\"}]]}"
