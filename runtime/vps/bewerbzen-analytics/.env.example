PORT=3466
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=n8n
PG_USER=n8n
PG_PASSWORD=replace_with_postgres_password

# Secret for read/admin endpoints and private writers.
BEWERBZEN_ANALYTICS_API_KEY=replace_with_long_random_secret

# Public browser write key. This is not a secret; it only separates expected site events from random posts.
BEWERBZEN_ANALYTICS_PUBLIC_KEY=replace_with_public_random_token

# Comma-separated origin allowlist for browser events.
BEWERBZEN_ALLOWED_ORIGINS=https://bewerbzen.de,https://www.bewerbzen.de,http://46.225.170.55
